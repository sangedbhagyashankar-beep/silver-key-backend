# ── Server ─────────────────────────────────────────────────────────────────────
PORT=5000
NODE_ENV=production

# ── MongoDB Atlas (Required) ───────────────────────────────────────────────────
# Free cluster: https://cloud.mongodb.com → Create Project → M0 Free
# Format: mongodb+srv://<user>:<password>@cluster0.xxxxx.mongodb.net/silverkeyhotel?retryWrites=true&w=majority
MONGO_URI=mongodb+srv://YOURUSER:YOURPASS@cluster0.xxxxx.mongodb.net/silverkeyhotel?retryWrites=true&w=majority

# ── JWT Secrets (Required) ─────────────────────────────────────────────────────
# Generate: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=REPLACE_WITH_64_CHAR_RANDOM_HEX
JWT_EXPIRES_IN=7d
JWT_REFRESH_SECRET=REPLACE_WITH_DIFFERENT_64_CHAR_RANDOM_HEX
JWT_REFRESH_EXPIRES_IN=30d

# ── Frontend URL for CORS + email links (Required) ─────────────────────────────
# Set this to your deployed frontend URL on Render
# e.g. https://silver-key-hotel.onrender.com
CLIENT_URL=https://YOUR-APP.vercel.app
FRONTEND_URL=

# ── Razorpay (Optional — demo mode works without it) ──────────────────────────
RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=

# ── Anthropic AI Chatbot (Optional) ───────────────────────────────────────────
ANTHROPIC_API_KEY=

# ── SMTP Email (Optional — booking confirmations) ─────────────────────────────
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your_gmail@gmail.com
SMTP_PASS=your_16_char_app_password
EMAIL_FROM=Silver Key Hotel <noreply@silverkeyhotel.com>

# ── Cloudinary (Optional — image uploads) ─────────────────────────────────────
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# ── WhatsApp Business API (Optional) ──────────────────────────────────────────
WHATSAPP_API_TOKEN=
WHATSAPP_PHONE_NUMBER_ID=
WHATSAPP_VERIFY_TOKEN=silverkey_verify

# ── Seed control ───────────────────────────────────────────────────────────────
# Set to 'true' ONLY on first deploy to populate demo rooms/data, then remove
SEED_DB=false
