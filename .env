PORT=5000
MONGO_URI=mongodb://127.0.0.1:27017/silverkeyhotel
JWT_SECRET=silverkey_jwt_secret_2024
JWT_EXPIRES_IN=7d
JWT_REFRESH_SECRET=silverkey_refresh_2024
JWT_REFRESH_EXPIRES_IN=30d
CLIENT_URL=http://localhost:5173
NODE_ENV=development

# ── Razorpay (leave blank for demo mode) ──────────────────────────
# Get keys from https://dashboard.razorpay.com → Settings → API Keys
RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=

# ── Anthropic AI Chatbot (optional but recommended) ───────────────
# Get key from https://console.anthropic.com
ANTHROPIC_API_KEY=

# ── Email (optional) ──────────────────────────────────────────────
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
EMAIL_FROM=Silver Key Hotel <noreply@silverkey.com>

# ── Cloudinary (optional, for room image uploads) ─────────────────
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# ── WhatsApp (optional) ───────────────────────────────────────────
WHATSAPP_API_TOKEN=
WHATSAPP_PHONE_NUMBER_ID=
WHATSAPP_VERIFY_TOKEN=silverkey_verify
